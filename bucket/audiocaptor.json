{
  "version": "0.1.0",
  "description": "AudioCaptor — portable audio recording application",
  "homepage": "https://github.com/ruslan-rv-ua/AudioCaptor",
  "license": "MIT",
  "architecture": {
    "64bit": {
      "url": "https://github.com/ruslan-rv-ua/AudioCaptor/releases/download/v0.1.0/AudioCaptor.exe",
      "hash": "PLACEHOLDER_SHA256_FILL_ON_RELEASE"
    }
  },
  "bin": "AudioCaptor.exe",
  "pre_install": [
    "if (!(Test-Path \"$persist_dir\\AudioCaptor-data\")) {",
    "    New-Item -ItemType Directory -Force -Path \"$dir\\AudioCaptor-data\" | Out-Null",
    "}"
  ],
  "persist": "AudioCaptor-data",
  "checkver": { "github": "https://github.com/ruslan-rv-ua/AudioCaptor" },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/ruslan-rv-ua/AudioCaptor/releases/download/v$version/AudioCaptor.exe"
      }
    }
  }
}
