{
  "version": "0.1.1",
  "description": "Portable Windows desktop app for quick access to text snippets",
  "homepage": "https://github.com/ruslan-rv-ua/quick-snippets",
  "license": "MIT",
  "notes": [
    "QuickSnippets is a portable app — your data files (snippets.db, settings.json)",
    "are stored next to the executable and preserved across Scoop updates.",
    "Use Ctrl+Shift+Space (default) to toggle the snippet window."
  ],
  "architecture": {
    "64bit": {
      "url": "https://github.com/ruslan-rv-ua/quick-snippets/releases/download/v0.1.1/quick-snippets-0.1.1-windows-x64.zip",
      "hash": "f02ebe601912f553c3ddb78fcfe757f8beb12b5a7098c505fb05f279a069b5ab"
    }
  },
  "bin": "quick-snippets.exe",
  "shortcuts": [
    [
      "quick-snippets.exe",
      "QuickSnippets"
    ]
  ],
  "pre_install": [
    "# Ensure persisted paths are files, not directories.",
    "# Scoop creates directory stubs for persist entries that don't exist in",
    "# the archive; the app detects this at runtime, but pre_install keeps",
    "# the first launch clean without any recovery dialog.",
    "if (!(Test-Path \"$persist_dir\\settings.json\") -or (Get-Item \"$persist_dir\\settings.json\").PSIsContainer) {",
    "    if (Test-Path \"$persist_dir\\settings.json\") { Remove-Item -Recurse -Force \"$persist_dir\\settings.json\" }",
    "    '{}' | Set-Content \"$dir\\settings.json\" -Encoding UTF8",
    "}",
    "if (!(Test-Path \"$persist_dir\\snippets.db\") -or (Get-Item \"$persist_dir\\snippets.db\").PSIsContainer) {",
    "    if (Test-Path \"$persist_dir\\snippets.db\") { Remove-Item -Recurse -Force \"$persist_dir\\snippets.db\" }",
    "    [System.IO.File]::WriteAllBytes(\"$dir\\snippets.db\", @())",
    "}"
  ],
  "persist": [
    "settings.json",
    "snippets.db"
  ],
  "checkver": {
    "github": "https://github.com/ruslan-rv-ua/quick-snippets"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/ruslan-rv-ua/quick-snippets/releases/download/v$version/quick-snippets-windows-x64-v$version.zip"
      }
    },
    "hash": {
      "url": "$url.sha256"
    }
  }
}
