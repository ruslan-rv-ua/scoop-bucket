{
  "version": "0.1.2",
  "description": "Portable Windows desktop app for quick access to text snippets",
  "homepage": "https://github.com/ruslan-rv-ua/quick-snippets",
  "license": "MIT",
  "notes": [
    "QuickSnippets is a portable app — your data files (snippets.db, settings.json)",
    "are stored next to the executable and preserved across Scoop updates.",
    "Use Ctrl+Shift+Space (default) to toggle the snippet window."
  ],
  "architecture": {
    "64bit": {
      "url": "https://github.com/ruslan-rv-ua/quick-snippets/releases/download/v0.1.2/quick-snippets-0.1.2-windows-x64.zip",
      "hash": "fb89459c9368c0994ca2edb8c3cf8a3d998ae6ac4fdd085bdb444b1481fe685c"
    }
  },
  "bin": "quick-snippets.exe",
  "shortcuts": [
    [
      "quick-snippets.exe",
      "QuickSnippets"
    ]
  ],
  "pre_install": [
    "# Ensure quick-snippets-data exists as a real directory, not a Scoop stub.",
    "if (!(Test-Path \"$persist_dir\\quick-snippets-data\")) {",
    "    New-Item -ItemType Directory -Force -Path \"$dir\\quick-snippets-data\" | Out-Null",
    "}"
  ],
  "persist": [
    "quick-snippets-data"
  ],
  "checkver": {
    "github": "https://github.com/ruslan-rv-ua/quick-snippets"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/ruslan-rv-ua/quick-snippets/releases/download/v$version/quick-snippets-$version-windows-x64.zip"
      }
    },
    "hash": {
      "url": "$url.sha256"
    }
  }
}
