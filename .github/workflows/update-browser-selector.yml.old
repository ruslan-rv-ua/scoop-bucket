# Назва workflow — відображається в GitHub Actions
name: Update BrowserSelector manifest

# Цей workflow запускається двома способами:
on:
  # 1. Автоматично: коли інший репозиторій надсилає подію 'update-manifest'
  #    (це робить release.yml після публікації нового релізу)
  repository_dispatch:
    types: [update-manifest]

  # 2. Вручну: через інтерфейс GitHub Actions із заповненням форми
  workflow_dispatch:
    inputs:
      version:
        description: 'Version (without v prefix)'  # Версія без 'v', наприклад: 1.2.3
        required: true
      hash:
        description: 'SHA256 hash'                  # Хеш ZIP-архіву
        required: true
      url:
        description: 'Download URL'                 # Пряме посилання на ZIP
        required: true

# Дозволяємо workflow записувати у вміст репозиторію
# (потрібно для commit + push оновленого маніфесту)
permissions:
  contents: write

jobs:
  update:
    # Запускаємо на Linux (Ubuntu) — достатньо для роботи з JSON і git
    runs-on: ubuntu-latest
    
    steps:
      # Крок 1: Клонуємо репозиторій scoop-bucket
      - name: Checkout bucket
        uses: actions/checkout@v4

      # Крок 2: Визначаємо звідки прийшли дані (автоматичний запуск чи ручний)
      # і записуємо версію, хеш та URL в outputs для використання в наступних кроках
      - name: Get payload
        id: payload
        run: |
          if [ "${{ github.event_name }}" = "repository_dispatch" ]; then
            # Автоматичний запуск: беремо дані з client_payload події
            echo "VERSION=${{ github.event.client_payload.version }}" >> $GITHUB_OUTPUT
            echo "HASH=${{ github.event.client_payload.hash }}" >> $GITHUB_OUTPUT
            echo "URL=${{ github.event.client_payload.url }}" >> $GITHUB_OUTPUT
          else
            # Ручний запуск: беремо дані з полів форми workflow_dispatch
            echo "VERSION=${{ github.event.inputs.version }}" >> $GITHUB_OUTPUT
            echo "HASH=${{ github.event.inputs.hash }}" >> $GITHUB_OUTPUT
            echo "URL=${{ github.event.inputs.url }}" >> $GITHUB_OUTPUT
          fi

      # Крок 3: Оновлюємо JSON-маніфест Scoop пакету
      # Scoop — менеджер пакетів для Windows, читає маніфест щоб знати
      # яку версію завантажувати і як перевірити цілісність файлу
      - name: Update manifest
        run: |
          VERSION="${{ steps.payload.outputs.VERSION }}"
          HASH="${{ steps.payload.outputs.HASH }}"
          URL="${{ steps.payload.outputs.URL }}"
          
          echo "Updating manifest to version $VERSION"
          echo "Hash: $HASH"
          echo "URL: $URL"
          
          # Оновлюємо поля у JSON-файлі маніфесту за допомогою jq
          # jq — утиліта для обробки JSON у командному рядку
          # Змінюємо три поля:
          #   .version               — номер версії пакету
          #   .architecture."64bit".url  — посилання для завантаження 64-бітної версії
          #   .architecture."64bit".hash — SHA256-хеш для перевірки завантаження
          jq --arg version "$VERSION" \
             --arg hash "$HASH" \
             --arg url "$URL" \
             '.version = $version | 
              .architecture."64bit".url = $url | 
              .architecture."64bit".hash = $hash' \
             bucket/browserselector.json > bucket/browserselector.json.tmp
          
          # Замінюємо оригінальний файл оновленим
          # (не можна писати jq безпосередньо в той самий файл)
          mv bucket/browserselector.json.tmp bucket/browserselector.json
          
          # Виводимо оновлений маніфест у лог для перевірки
          echo "Updated manifest:"
          cat bucket/browserselector.json

      # Крок 4: Зберігаємо зміни у репозиторій
      - name: Commit and push
        run: |
          # Налаштовуємо git від імені бота (щоб commits мали автора)
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          
          # Додаємо змінений маніфест до індексу git
          git add bucket/browserselector.json
          
          # Перевіряємо чи є реальні зміни (щоб не робити порожній commit)
          if git diff --staged --quiet; then
            echo "No changes to commit"  # Маніфест вже актуальний — нічого не робимо
          else
            # Створюємо commit з описом нової версії і пушимо у репозиторій
            git commit -m "Update browserselector to ${{ steps.payload.outputs.VERSION }}"
            git push
          fi
